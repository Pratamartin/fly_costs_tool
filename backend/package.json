{
  "name": "fly-costs-tool-api",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "prisma generate",
    "typecheck": "prisma generate && tsc --noEmit",
    "build": "tsc && tsc-alias",
    "start": "node dist/src/index.js",
    "pretest": "cross-env NODE_ENV=test prisma generate",
    "test": "vitest run",
    "test:watch": "npm run pretest && vitest",
    "test:coverage": "npm run pretest && vitest run --coverage",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "db:ui": "prisma studio --port 5555",
    "db:seed": "prisma db seed",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:sync": "prisma db pull",
    "jobs:ui": "cross-env PORT=5001 pg-boss-dashboard"
  },
  "dependencies": {
    "@apideck/better-ajv-errors": "^0.3.7",
    "@aws-sdk/client-s3": "^3.939.0",
    "@aws-sdk/lib-storage": "^3.939.0",
    "@aws-sdk/s3-request-presigner": "^3.939.0",
    "@hono/ajv-validator": "^0.0.2",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-openapi": "^1.2.3",
    "@pg-boss/dashboard": "^1.1.3",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@scalar/hono-api-reference": "^0.10.5",
    "ajv": "^8.20.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "bcryptjs": "^3.0.3",
    "cpf-cnpj-validator": "^2.1.0",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.0",
    "dotenv-expand": "^12.0.3",
    "googleapis": "^171.4.0",
    "hono": "^4.12.9",
    "hono-pino": "^0.10.3",
    "hono-problem-details": "^0.8.1",
    "nodemailer": "^8.0.7",
    "pdfmake": "^0.3.9",
    "pg": "^8.20.0",
    "pg-boss": "^12.18.2",
    "prisma": "^7.5.0",
    "stoker": "^2.0.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^20.11.17",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfmake": "^0.2.11",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^2.0.1",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.3"
  }
}
