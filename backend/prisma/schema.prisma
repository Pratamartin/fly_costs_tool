generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  passwordHash    String
  role            UserRole         @default(ALUNO)
  expenseRequests ExpenseRequest[]
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

enum UserRole {
  ALUNO
  COORDENADOR
  ADMIN
}

enum ExpenseRequestStatus {
  PENDENTE
  APROVADO
  REJEITADO
}

model ExpenseCategory {
  id             String @id @default(uuid())
  name           String
  normalizedName String @unique

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseRequest {
  id        String @id @default(uuid())
  studentId String
  student   User   @relation(fields: [studentId], references: [id])

  status ExpenseRequestStatus @default(PENDENTE)

  title       String
  description String?

  city    String
  state   String @db.VarChar(6) // ISO 3166-2 (e.g., "US-NY", "BR-AM")
  country String @db.Char(2) // ISO 3166-1 (e.g., "US", "BR")

  departureDate DateTime
  returnDate    DateTime

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id                String            @id @default(uuid())
  name              String
  code              String            @unique
  budget            Decimal
  expenseCategories ExpenseCategory[]
  expenseRequests   ExpenseRequest[]
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}
