{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Preference Survey Schemas",
  "definitions": {
    "diarias": {
      "title": "Auxílio Diárias",
      "type": "object",
      "required": ["requested"],
      "properties": {
        "requested": {
          "type": "boolean",
          "const": true,
          "title": "Solicitar Diárias?"
        }
      }
    },
    "inscricao": {
      "title": "Solicitação de Inscrição",
      "type": "object",
      "properties": {
        "invoiceKey": {
          "type": "string",
          "format": "r2-key",
          "title": "Chave do Comprovante (Boleto/Invoice)",
          "description": "Caminho (key) do arquivo salvo no R2 referente ao boleto ou invoice.",
          "pattern": "^formulario-preferencias\\/[\\w/.-]+$"
        }
      }
    },
    "passagem-aerea": {
      "title": "Solicitação de Passagem",
      "type": "object",
      "properties": {
        "departureDate": { 
          "type": "string", 
          "format": "date", 
          "title": "Data Ida",
          "x-report": true
        },
        "returnDate": { 
          "type": "string", 
          "format": "date", 
          "title": "Data Volta",
          "x-report": true,
          "dateAfter": { 
            "$data": "1/departureDate" 
          } 
        },
        "departureRoute": { 
          "type": "string", 
          "title": "Trecho Ida",
          "x-report": true
        },
        "returnRoute": { 
          "type": "string", 
          "title": "Trecho Volta",
          "x-report": true
        },
        "flightSuggestionKey": { 
          "type": "string", 
          "format": "r2-key", 
          "title": "Sugestão de Voo (R2 Key)",
          "description": "Caminho (key) do arquivo salvo no R2 referente à sugestão de voo.",
          "pattern": "^formulario-preferencias\\/[\\w/.-]+$"
        }
      },
      "required": [
        "departureDate", 
        "returnDate", 
        "departureRoute", 
        "returnRoute"
      ]
    }
  }
}
