{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Preference Survey Schemas",
  "definitions": {
    "hospedagem": {
      "title": "Auxílio Hospedagem",
      "type": "boolean"
    },
    "inscricao": {
      "title": "Solicitação de Inscrição",
      "type": "object",
      "properties": {
        "invoiceKey": {
          "type": "string",
          "format": "r2-key",
          "title": "Anexar Boleto/Invoice"
        }
      },
      "required": [
        "invoiceKey"
      ]
    },
    "passagem-aerea": {
      "title": "Solicitação de Passagem",
      "type": "object",
      "properties": {
        "departureDate": { 
          "type": "string", 
          "format": "date", 
          "title": "Data Ida",
          "x-report": true
        },
        "returnDate": { 
          "type": "string", 
          "format": "date", 
          "title": "Data Volta",
          "x-report": true,
          "dateAfter": { 
            "$data": "1/departureDate" 
          } 
        },
        "departureRoute": { 
          "type": "string", 
          "title": "Trecho Ida",
          "x-report": true
        },
        "returnRoute": { 
          "type": "string", 
          "title": "Trecho Volta",
          "x-report": true
        },
        "flightSuggestionKey": { 
          "type": "string", 
          "format": "r2-key", 
          "title": "Sugestão de Voo" 
        }
      },
      "required": [
        "departureDate", 
        "returnDate", 
        "departureRoute", 
        "returnRoute"
      ]
    }
  }
}
