{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Detalhes do Evento",
  "description": "Informações sobre o evento acadêmico relacionado à solicitação de auxílio.",
  "type": "object",
  "properties": {
    "name": { 
      "type": "string",
      "minLength": 3,
      "title": "Nome do Evento"
    },
    "location": { 
      "type": "string",
      "minLength": 3,
      "title": "Localização do Evento"
    }
  },
  "required": [
    "name", 
    "location"
  ],
  "examples": [
    {
      "name": "Simpósio Brasileiro de Engenharia de Software (SBES)",
      "location": "Rio de Janeiro/RJ"
    }
  ]
}
