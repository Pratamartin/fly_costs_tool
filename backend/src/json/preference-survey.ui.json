{
  "passagem-aerea": {
    "type": "Group",
    "label": "Planejamento de Voo",
    "elements": [
      {
        "type": "HorizontalLayout",
        "elements": [
          {
            "type": "Control",
            "scope": "#/properties/departureDate",
            "label": "Data de Ida"
          },
          {
            "type": "Control",
            "scope": "#/properties/returnDate",
            "label": "Data de Retorno"
          }
        ]
      },
      {
        "type": "HorizontalLayout",
        "elements": [
          {
            "type": "Control",
            "scope": "#/properties/departureRoute",
            "options": {
              "placeholder": "ex.: Manaus/AM para Rio Branco/AC"
            }
          },
          {
            "type": "Control",
            "scope": "#/properties/returnRoute",
            "options": {
              "placeholder": "ex.: Rio Branco/AC para Manaus/AM"
            }
          }
        ]
      },
      {
        "type": "Control",
        "scope": "#/properties/flightSuggestionKey",
        "label": "Sugestão de Voo",
        "options": {
          "widget": "file-upload"
        }
      }
    ]
  },
  "inscricao": {
    "type": "Group",
    "label": "Documentação de Inscrição",
    "elements": [
      {
        "type": "Control",
        "scope": "#/properties/invoiceKey",
        "options": {
          "widget": "file-upload"
        }
      }
    ]
  },
  "hospedagem": {
    "type": "Control",
    "scope": "#",
    "label": "Desejo solicitar auxílio hospedagem (diárias)",
    "options": {
      "toggle": true
    }
  }
}
